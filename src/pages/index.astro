---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="es" class="scroll-smooth bg-[#0D131A] text-slate-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Natalia Blanco | Portfolio Creativo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>

  <body class="antialiased overflow-x-hidden relative selection:bg-[#05FFD1]/30 min-h-screen">
    
    <!-- FONDO DINÁMICO: Lienzo de destellos cian/menta eléctricos -->
    <canvas id="starsCanvas" class="fixed inset-0 w-full h-full pointer-events-none z-0 opacity-40"></canvas>
    
    <!-- CURSOR MAGNÉTICO PERSONALIZADO (Cian Neón Fluido) -->
    <div id="customCursor" class="hidden md:block fixed w-8 h-8 rounded-full border border-[#05FFD1]/60 pointer-events-none z-50 transition-transform duration-100 -translate-x-1/2 -translate-y-1/2 bg-[#00F2FE]/10 blur-[1px]"></div>

    <!-- CONTENEDOR DE LA INTERFAZ -->
    <div class="relative z-10">

      <!-- 1. HERO SECTION -->
      <section class="min-h-screen flex flex-col justify-center items-center px-6 relative">
        <div class="text-center max-w-5xl space-y-8">
          <div class="reveal-slide tracking-widest text-xs font-mono uppercase bg-[#141E28] border border-[#1F2E3D] text-[#05FFD1] px-4 py-2 rounded-full inline-block shadow-[0_0_15px_rgba(5,255,209,0.1)]">
            // STATUS: ECO SITEMA AUTÓNOMO ACTIVO
          </div>
          
          <!-- Título con efecto de aparición letra por letra -->
          <h1 class="text-6xl sm:text-7xl md:text-9xl font-extrabold tracking-tighter uppercase font-space leading-none py-2 overflow-hidden">
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-slate-100 via-slate-300 to-[#4FACFE] animate-split-text" data-text="Natalia">Natalia</span>
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-[#05FFD1] via-[#00F2FE] to-[#4FACFE] animate-split-text" data-text="Blanco" style="animation-delay: 0.4s;">Blanco</span>
          </h1>

          <p class="text-lg md:text-2xl text-slate-400 font-light max-w-2xl mx-auto leading-relaxed text-balance reveal-slide" style="transition-delay: 0.6s;">
            Desarrolladora Full-Stack combinando <span class="text-[#05FFD1] font-semibold">Ingeniería del Dato</span> y sistemas autónomos basados en Inteligencia Artificial.
          </p>

          <div class="pt-8 reveal-slide" style="transition-delay: 0.8s;">
            <a href="#proyectos" class="inline-flex items-center gap-3 bg-gradient-to-r from-[#05FFD1] to-[#00F2FE] text-[#0D131A] px-8 py-4 rounded-full font-bold hover:brightness-110 transition-all duration-500 transform hover:scale-105 shadow-xl shadow-[#05FFD1]/10 text-xs tracking-wider uppercase font-space">
              Ver ecosistema
              <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- 2. PROYECTOS / METAMORFOSIS INTERACTIVA 3D -->
      <section id="proyectos" class="py-32 max-w-6xl mx-auto px-6" x-data="{ proyecto: 'dam' }">
        
        <div class="mb-20 text-center md:text-left">
          <h2 class="text-xs font-mono uppercase text-[#05FFD1] tracking-widest mb-3 reveal-slide">// EVOLUCIÓN ACADÉMICA</h2>
          <!-- Título que se dividirá dinámicamente al hacer scroll -->
          <h3 class="text-4xl md:text-6xl font-bold font-space tracking-tight text-slate-100 reveal-split">Del Software Móvil a la Automatización Cognitiva</h3>
          
          <div class="mt-8 inline-flex bg-[#141E28] border border-[#1F2E3D] p-1.5 rounded-xl shadow-inner reveal-slide" style="transition-delay: 0.3s;">
            <button @click="proyecto = 'dam'" :class="proyecto === 'dam' ? 'bg-gradient-to-r from-[#05FFD1] to-[#00F2FE] text-[#0D131A] shadow-lg' : 'text-slate-400 hover:text-slate-200'" class="px-6 py-3 rounded-lg text-xs font-bold uppercase tracking-wider transition-all duration-300 cursor-pointer font-space">
              Fase 01: DAM (Móvil)
            </button>
            <button @click="proyecto = 'daw'" :class="proyecto === 'daw' ? 'bg-gradient-to-r from-[#05FFD1] to-[#00F2FE] text-[#0D131A] shadow-lg' : 'text-slate-400 hover:text-slate-200'" class="px-6 py-3 rounded-lg text-xs font-bold uppercase tracking-wider transition-all duration-300 cursor-pointer font-space">
              Fase 02: DAW + IA (Web)
            </button>
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-16 items-center">
          <!-- Textos Técnicos -->
          <div class="lg:col-span-6 space-y-8">
            <div x-show="proyecto === 'dam'" x-transition:enter="transition-all duration-700 ease-out" x-transition:enter-start="opacity-0 translate-y-8 filter blur-sm" x-transition:enter-end="opacity-100 translate-y-0 filter blur-0" class="space-y-6">
              <h4 class="text-3xl font-bold font-space text-slate-200">Gestión Transaccional Multiplataforma</h4>
              <p class="text-slate-400 text-lg leading-relaxed">
                Desarrollo en entorno nativo Android (Java) con una arquitectura distribuida orientada a servicios. Estructuración analítica de una base de datos relacional para orquestar con precisión quirúrgica un entorno de 4 roles humanos.
              </p>
              <div class="p-4 bg-[#141E28]/60 rounded-xl border border-[#1F2E3D] font-mono text-xs text-slate-400 space-y-1">
                <span class="text-[#05FFD1] font-bold block">// ROLES TRADICIONALES INVOLUCRADOS</span>
                <p>Cliente • Asistente Operativo • Gestor de Filial • Administrador General</p>
              </div>
            </div>

            <div x-show="proyecto === 'daw'" x-transition:enter="transition-all duration-700 ease-out" x-transition:enter-start="opacity-0 translate-y-8 filter blur-sm" x-transition:enter-end="opacity-100 translate-y-0 filter blur-0" x-cloak class="space-y-6">
              <h4 class="text-3xl font-bold font-space text-slate-200">Migración Arquitectónica e Integración IA</h4>
              <p class="text-slate-400 text-lg leading-relaxed">
                Salto disruptivo hacia ecosistemas web basados en JavaScript. Refactorización completa del backend para ganar elasticidad. La innovación clave consistió en optimizar el motor relacional y delegar tareas de soporte masivo a un Agente de Inteligencia Artificial.
              </p>
              <div class="p-4 bg-[#00F2FE]/5 rounded-xl border border-[#00F2FE]/20 font-mono text-xs text-slate-400 space-y-1">
                <span class="text-[#05FFD1] font-bold block">// OPTIMIZACIÓN AGENTE COGNITIVO</span>
                <p>Un bot de IA asume autónomamente la lógica analítica de los antiguos asistentes físicos.</p>
              </div>
            </div>
          </div>

          <!-- CONTENEDOR 3D INTERACTIVO REAL -->
          <div class="lg:col-span-6 flex justify-center reveal-slide" style="transition-delay: 0.2s;">
            <div id="card3D" class="w-full max-w-sm aspect-[4/5] bg-gradient-to-br from-[#141E28] to-[#0D131A] border border-[#1F2E3D] p-8 rounded-[2rem] shadow-[0_30px_70px_rgba(5,255,209,0.03)] transition-transform duration-200 ease-out relative flex flex-col justify-center items-center overflow-hidden">
              <div id="cardGlow" class="absolute w-56 h-56 rounded-full bg-[#05FFD1]/10 blur-[50px] pointer-events-none -translate-x-1/2 -translate-y-1/2"></div>

              <!-- Simulación Móvil DAM -->
              <div x-show="proyecto === 'dam'" class="w-40 h-72 bg-[#0D131A] border-2 border-[#1F2E3D] rounded-[2rem] p-3 flex flex-col justify-between shadow-2xl relative">
                <div class="w-12 h-3 bg-[#1F2E3D] rounded-full mx-auto"></div>
                <div class="space-y-2 flex-1 flex flex-col justify-center">
                  <div class="bg-[#05FFD1]/10 border border-[#05FFD1]/30 text-[#05FFD1] text-[10px] font-mono py-1 rounded text-center">4 ROLES ACTIVOS</div>
                  <div class="bg-[#141E28] p-2 rounded text-[10px] font-mono text-slate-400 text-center">Gestión Humana</div>
                </div>
                <div class="w-8 h-8 rounded-full border border-[#1F2E3D] mx-auto"></div>
              </div>

              <!-- Simulación Web DAW -->
              <div x-show="proyecto === 'daw'" x-cloak class="w-full bg-[#0D131A] rounded-xl border border-[#1F2E3D] shadow-2xl overflow-hidden p-4 space-y-3">
                <div class="flex gap-1 border-b border-[#1F2E3D] pb-2">
                  <div class="w-2 h-2 rounded-full bg-[#05FFD1]"></div>
                  <div class="w-2 h-2 rounded-full bg-[#00F2FE]"></div>
                  <div class="w-2 h-2 rounded-full bg-[#4FACFE]"></div>
                </div>
                <div class="border border-[#05FFD1]/20 rounded-lg p-4 bg-[#05FFD1]/5 flex items-center gap-4 relative overflow-hidden">
                  <div class="w-10 h-10 rounded-full bg-gradient-to-r from-[#05FFD1] to-[#00F2FE] flex items-center justify-center text-[#0D131A] text-lg shadow-lg shadow-[#05FFD1]/20 animate-pulse">🤖</div>
                  <div class="space-y-1 flex-1">
                    <span class="text-xs font-bold text-slate-200 block font-space">AGENTE COGNITIVO</span>
                    <span class="text-[10px] text-[#05FFD1] block font-mono">Automatizando...</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 3. INTERFAZ BENTO GRID EXPERIMENTAL -->
      <section class="py-32 bg-[#090D12] border-t border-[#1F2E3D] relative">
        <div class="max-w-6xl mx-auto px-6">
          
          <div class="mb-20 text-center">
            <h2 class="text-xs font-mono uppercase text-[#05FFD1] tracking-widest mb-2 reveal-slide">// CORE INGENIERÍA</h2>
            <h3 class="text-4xl font-bold font-space tracking-tight text-slate-100 reveal-split">Capacidades del Sistema</h3>
          </div>

          <div class="grid md:grid-cols-3 gap-6">
            <!-- Bloque Grande 1 -->
            <div class="md:col-span-2 bg-[#141E28]/40 border border-[#1F2E3D] p-8 rounded-3xl reveal-slide flex flex-col justify-between group hover:border-[#05FFD1]/40 transition-all duration-500 min-h-[250px]">
              <div class="space-y-3">
                <span class="text-2xl group-hover:rotate-12 block transition-transform duration-300 w-fit">⚡</span>
                <h4 class="text-xl font-bold font-space text-slate-200">Lógica de Datos & Motores Relacionales</h4>
                <p class="text-slate-400 text-sm leading-relaxed">Modelado matemático y estructuración relacional de bases de datos de alto rendimiento. Optimización de consultas complejas y control estricto de concurrencia de accesos.</p>
              </div>
              <span class="text-[10px] font-mono text-[#05FFD1] tracking-widest uppercase">// INFRAESTRUCTURA • SQL</span>
            </div>

            <!-- Bloque Pequeño 1 -->
            <div class="bg-[#141E28]/40 border border-[#1F2E3D] p-8 rounded-3xl reveal-slide flex flex-col justify-between group hover:border-[#05FFD1]/40 transition-all duration-500" style="transition-delay: 0.1s;">
              <div class="space-y-3">
                <span class="text-2xl block group-hover:scale-110 transition-transform">💻</span>
                <h4 class="text-xl font-bold font-space text-slate-200">Desarrollo Full-Stack</h4>
                <p class="text-slate-400 text-sm leading-relaxed">Ecosistemas acoplados de frontend modular y backends dinámicos y limpios.</p>
              </div>
              <span class="text-[10px] font-mono text-[#05FFD1] tracking-widest uppercase">// ES6 • JAVA • PHP</span>
            </div>

            <!-- Bloque Pequeño 2 -->
            <div class="bg-[#141E28]/40 border border-[#1F2E3D] p-8 rounded-3xl reveal-slide flex flex-col justify-between group hover:border-[#05FFD1]/40 transition-all duration-500" style="transition-delay: 0.2s;">
              <div class="space-y-3">
                <span class="text-2xl block group-hover:animate-pulse">🧠</span>
                <h4 class="text-xl font-bold font-space text-slate-200">Integración de Agentes IA</h4>
                <p class="text-slate-400 text-sm leading-relaxed">Automatización inteligente sustituyendo lógica repetitiva humana por modelos autónomos cognitivos.</p>
              </div>
              <span class="text-[10px] font-mono text-[#05FFD1] tracking-widest uppercase">// AGENTES • AUTOMACIÓN</span>
            </div>

            <!-- Bloque Grande 2 -->
            <div class="md:col-span-2 bg-gradient-to-br from-[#00F2FE]/5 to-[#141E28]/20 border border-[#00F2FE]/20 p-8 rounded-3xl reveal-slide flex flex-col justify-between hover:border-[#05FFD1]/50 transition-all duration-500 min-h-[250px]" style="transition-delay: 0.3s;">
              <div class="space-y-3">
                <span class="text-2xl text-[#05FFD1] block">👁️‍🗨️</span>
                <h4 class="text-xl font-bold font-space text-slate-200">Resolución de Complejidad Organizativa</h4>
                <p class="text-slate-400 text-sm leading-relaxed">Mi propuesta de valor diferenciadora no se limita a escribir código limpio. Radica en la capacidad adquirida para auditar flujos analíticos confusos y desestructurados de cuatro o más niveles de accesos de personal para sintetizarlos en software fluido, centralizado y optimizado.</p>
              </div>
              <span class="text-[10px] font-mono text-[#05FFD1] tracking-widest uppercase">// VISIÓN CRÍTICA • ARQUITECTURA</span>
            </div>
          </div>

        </div>
      </section>

      <!-- FOOTER -->
      <footer class="py-16 text-center text-xs text-slate-600 border-t border-[#1F2E3D] font-mono">
        <p>© 2026 NATALIA BLANCO DÍAZ. SISTEMA OPERATIVO CONSTRUIDO BAJO ASTRO + TAILWIND V4.</p>
      </footer>

    </div>
  </body>
</html>

<!-- SCRIPTS DE ANIMACIONES MÁGICAS -->
<script>
  // 1. GENERACIÓN DE CARACTERES PARA HERO TEXT (Efecto cinemático)
  document.querySelectorAll('.animate-split-text').forEach(el => {
    const text = el.getAttribute('data-text');
    el.innerHTML = text.split('').map((char, i) => 
      `<span class="inline-block translate-y-[110%] opacity-0 filter blur-[4px] animate-char" style="animation-delay: ${(i * 0.04) + parseFloat(el.style.animationDelay || 0)}s">${char === ' ' ? '&nbsp;' : char}</span>`
    ).join('');
  });

  // 2. CANVAS DE PARTICULAS FLUIDAS
  const canvas = document.getElementById('starsCanvas');
  const ctx = canvas.getContext('2d');
  let stars = [];

  function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    initStars();
  }

  function initStars() {
    stars = [];
    const numStars = window.innerWidth < 768 ? 40 : 90;
    for (let i = 0; i < numStars; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        size: Math.random() * 1.8,
        speed: Math.random() * 0.25 + 0.05,
        color: Math.random() > 0.5 ? 'rgba(5, 255, 209, 0.4)' : 'rgba(0, 242, 254, 0.3)'
      });
    }
  }

  function animateStars() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stars.forEach(star => {
      ctx.beginPath();
      ctx.fillStyle = star.color;
      ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
      ctx.fill();
      star.y -= star.speed;
      if (star.y < 0) {
        star.y = canvas.height;
        star.x = Math.random() * canvas.width;
      }
    });
    requestAnimationFrame(animateStars);
  }

  window.addEventListener('resize', resizeCanvas);
  resizeCanvas();
  animateStars();

  // 3. CURSOR INTELIGENTE
  const cursor = document.getElementById('customCursor');
  document.addEventListener('mousemove', (e) => {
    cursor.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0)`;
  });

  // 4. EFECTO TARJETA 3D
  const card = document.getElementById('card3D');
  const glow = document.getElementById('cardGlow');

  card.addEventListener('mousemove', (e) => {
    const rect = card.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    const xc = rect.width / 2;
    const yc = rect.height / 2;
    card.style.transform = `perspective(1000px) rotateX(${(yc - y) / 12}deg) rotateY(${(x - xc) / 12}deg) scale3d(1.02, 1.02, 1.02)`;
    glow.style.left = `${x}px`;
    glow.style.top = `${y}px`;
  });

  card.addEventListener('mouseleave', () => {
    card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)';
  });

  // 5. INTERSECTION OBSERVER AVANZADO (Apariciones secuenciales controladas al Scroll)
  const observerOptions = { threshold: 0.15, rootMargin: "0px 0px -50px 0px" };

  // Animación para bloques de texto y grids (Efecto máscara fluida)
  const slideObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
        slideObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal-slide').forEach(el => slideObserver.observe(el));

  // Animación para subtítulos interactivos por letras al hacer scroll
  const splitObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const text = entry.target.innerText;
        entry.target.innerHTML = text.split('').map((char, i) => 
          `<span class="inline-block translate-y-[100%] opacity-0 filter blur-[2px] animate-scroll-char" style="animation-delay: ${i * 0.02}s">${char === ' ' ? '&nbsp;' : char}</span>`
        ).join('');
        splitObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal-split').forEach(el => splitObserver.observe(el));
</script>

<style is:global>
  [x-cloak] { display: none !important; }

  .font-space {
    font-family: 'Space Grotesk', sans-serif;
  }

  /* Animación del Hero (Letra a Letra) */
  .animate-char {
    animation: charReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes charReveal {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  /* Animación disparada al hacer Scroll (Letra a Letra) */
  .animate-scroll-char {
    animation: scrollCharReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes scrollCharReveal {
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  /* Revelación Cinemática de Bloques de Texto */
  .reveal-slide {
    opacity: 0;
    transform: translateY(40px) scale(0.98);
    filter: blur(4px);
    transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1), 
                transform 1.2s cubic-bezier(0.16, 1, 0.3, 1),
                filter 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity, filter;
  }

  .reveal-slide.active {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
</style>