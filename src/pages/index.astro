---
// src/pages/index.astro
import '../styles/global.css';
---

<html lang="es" class="scroll-smooth bg-[#0D131A] text-slate-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Natalia Blanco | Portfolio Profesional Full-Stack</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>

  <body class="antialiased overflow-x-hidden relative selection:bg-[#05FFD1]/30 min-h-screen">
    
    <!-- Canvas de estrellas de fondo (Fijo y continuo) -->
    <canvas id="starsCanvas" class="fixed inset-0 w-full h-full pointer-events-none z-0 opacity-50"></canvas>
    
    <div id="customCursor" class="hidden md:block fixed w-8 h-8 rounded-full border border-[#05FFD1]/60 pointer-events-none z-50 bg-[#00F2FE]/10 blur-[1px] will-change-transform"></div>

    <div class="relative z-10">

      <nav class="fixed top-0 left-0 w-full bg-[#0D131A]/80 backdrop-blur-md border-b border-[#1F2E3D] z-40 px-6 py-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
          <span class="font-space font-bold text-sm tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-[#05FFD1] to-[#00F2FE]">BYNAT.DEV</span>
          <div class="flex items-center gap-6 text-xs font-mono text-slate-400">
            <a href="#sobre-mi" class="hover:text-[#05FFD1] transition-colors">Sobre Mí</a>
            <a href="#experiencia" class="hover:text-[#05FFD1] transition-colors">Trayectoria</a>
            <a href="#habilidades" class="hover:text-[#05FFD1] transition-colors">Ecosistema</a>
            <a href="#proyectos" class="hover:text-[#05FFD1] transition-colors">Evolución</a>
            <a href="/NataliaBlanco_CV.pdf" target="_blank" class="bg-[#05FFD1]/10 text-[#05FFD1] border border-[#05FFD1]/30 px-3 py-1.5 rounded-md hover:bg-[#05FFD1]/20 transition-all font-bold flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              CV .PDF
            </a>
          </div>
        </div>
      </nav>

      <!-- SECCIÓN PRINCIPAL DE ENTRADA -->
      <section class="min-h-screen flex flex-col justify-center items-center px-6 relative pt-20">
        <div class="text-center max-w-5xl space-y-8 flex flex-col items-center">
          <div class="reveal-slide tracking-widest text-xs font-mono uppercase bg-[#141E28] border border-[#1F2E3D] text-[#05FFD1] px-4 py-2 rounded-full inline-block shadow-[0_0_15px_rgba(5,255,209,0.1)]">
            // STATUS: FULL STACK DEVELOPER | DATA ANALYSTICS
          </div>
          
          <h1 class="text-6xl sm:text-7xl md:text-9xl font-extrabold tracking-tighter uppercase font-space leading-none py-2 flex flex-col gap-2">
            <span class="overflow-hidden block">
              <span class="block text-transparent bg-clip-text bg-gradient-to-r from-slate-100 via-slate-300 to-[#05FFD1] animate-hero-reveal">
                Natalia
              </span>
            </span>
            <span class="overflow-hidden block">
              <span class="block text-transparent bg-clip-text bg-gradient-to-r from-[#05FFD1] via-[#00F2FE] to-[#00d5ff] animate-hero-reveal" style="animation-delay: 0.2s;">
                Blanco
              </span>
            </span>
          </h1>

          <p class="text-lg md:text-2xl text-slate-400 font-light max-w-2xl mx-auto leading-relaxed text-balance reveal-slide" style="transition-delay: 0.5s;">
            • Desarrolladora Full-Stack • 
            <br>
            • Doble Graduada en DAM y DAW • 
            <br>
            <em style="font-size: 65%;">con bases en Ingeniería Informática</em>
          </p>

          <div class="flex flex-wrap gap-4 justify-center reveal-slide" style="transition-delay: 0.6s;">
            <a 
              href="/NataliaBlanco_CV.pdf" 
              download="NataliaBlanco_CV.pdf"
              target="_blank" 
              class="flex items-center gap-2 px-4 py-2 rounded-xl bg-gradient-to-r from-[#05FFD1]/20 to-[#00F2FE]/20 border border-[#05FFD1]/50 text-xs font-mono font-bold text-[#05FFD1] hover:scale-105 transition-all shadow-[0_0_15px_rgba(5,255,209,0.1)]"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              Descargar CV (PDF)
            </a>
            <a href="https://github.com/Nataliabd26" target="_blank" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[#141E28] border border-[#1F2E3D] hover:border-[#05FFD1] text-xs font-mono transition-all text-slate-300 hover:text-slate-100">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.137 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd"/></svg>
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/nblancodiaz/" target="_blank" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[#141E28] border border-[#1F2E3D] hover:border-[#05FFD1] text-xs font-mono transition-all text-slate-300 hover:text-slate-100">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              LinkedIn
            </a>
          </div>

          <div class="pt-4 reveal-slide" style="transition-delay: 0.7s;">
            <a href="#sobre-mi" class="inline-flex items-center gap-3 bg-gradient-to-r from-[#05FFD1] to-[#00F2FE] text-[#0D131A] px-8 py-4 rounded-full font-bold hover:brightness-110 transition-all duration-500 transform hover:scale-105 shadow-xl shadow-[#05FFD1]/10 text-xs tracking-wider uppercase font-space">
              Explorar Perfil
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 13l-7 7m0 0l-7-7m7 7V3"></path></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- 1. SOBRE MÍ -->
      <section id="sobre-mi" class="py-32 max-w-4xl mx-auto px-6 border-t border-[#1F2E3D]/50 relative z-10">
        <div class="grid md:grid-cols-12 gap-12 items-center">
          <div class="md:col-span-4 flex justify-center reveal-slide">
            <div class="relative w-48 h-48 rounded-full p-1 bg-gradient-to-br from-[#05FFD1] to-[#4FACFE] shadow-2xl transition-transform duration-500 hover:scale-105">
              <div class="w-full h-full rounded-full bg-[#0D131A] overflow-hidden flex items-center justify-center">
                <img 
                  src="src/images/perfil.jpg" 
                  alt="Natalia Blanco" 
                  class="w-full h-full object-cover rounded-full"             
                />
              </div>
            </div>
          </div>
          <div class="md:col-span-8 space-y-6 reveal-slide" style="transition-delay: 0.1s;">
            <span class="text-xs font-mono uppercase text-[#05FFD1] tracking-widest">// SOBRE MI</span>
            <h2 class="text-3xl font-bold font-space text-slate-100">Resolviendo flujos analíticos complejos</h2>
            <p class="text-slate-400 leading-relaxed">
              Mi trayectoria combina una base rigurosa en los dos primeros cursos de <strong>Ingeniería Informática (UCLM)</strong> con la especialización práctica del doble grado en <strong>DAM y DAW</strong>. Mi paso por entornos industriales altamente automatizados y mi experiencia como becaria en el <strong>Dto. Data & IA</strong> me han dotado de una mentalidad analítica habituada a la arquitectura limpia de procesos y la gestión avanzada de bases de datos. Además, soy comunicativa, resolutiva y tengo facilidad para trabajar en equipo.
            </p>
            <div class="flex flex-wrap gap-3 font-mono text-[11px] text-[#05FFD1]">
              <span class="px-3 py-1 bg-[#141E28] border border-[#1F2E3D] rounded-md">#FullStack</span>
              <span class="px-3 py-1 bg-[#141E28] border border-[#1F2E3D] rounded-md">#DataEngineering</span>
              <span class="px-3 py-1 bg-[#141E28] border border-[#1F2E3D] rounded-md">#DataAnalyst</span>
              <span class="px-3 py-1 bg-[#141E28] border border-[#1F2E3D] rounded-md">#IndustrialAutomation</span>
            </div>
          </div>
        </div>
      </section>

      <!-- 2. EXPERIENCIA Y FORMACIÓN -->
<section id="experiencia" class="py-32 bg-transparent border-t border-[#1F2E3D]/50 relative z-10 overflow-hidden">
        
        <div class="absolute inset-0 pointer-events-none z-0 opacity-30 mix-blend-screen">
          <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-[#05FFD1]/10 rounded-full blur-[130px]"></div>
          <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-[#00F2FE]/5 rounded-full blur-[130px]"></div>
        </div>

        <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="mb-16 text-center">
      <h2 class="text-xs font-mono uppercase text-[#05FFD1] tracking-widest mb-2">// LÍNEA DE TIEMPO</h2>
      <h3 class="text-4xl font-bold font-space text-slate-100">Experiencia y Formación</h3>
    </div>

    <!-- Contenedor principal de filas -->
    <div class="space-y-8 md:space-y-12">
      
      <!-- ENCABEZADOS DE COLUMNA (SÓLO VISIBLES EN MD HACIA ARRIBA) -->
      <div class="hidden md:grid md:grid-cols-2 gap-12">
        <h4 class="text-lg font-space text-[#05FFD1] font-bold tracking-wider uppercase">// EXPERIENCIA PROFESIONAL</h4>
        <h4 class="text-lg font-space text-[#05FFD1] font-bold tracking-wider uppercase">// EDUCACIÓN ACADÉMICA</h4>
      </div>

      <!-- FILA 1: INETUM + DAW -->
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-stretch">
        <div class="block md:hidden"><h4 class="text-md font-space text-[#05FFD1] font-bold tracking-wider uppercase mb-4">// EXPERIENCIA PROFESIONAL</h4></div>
        <!-- INETUM -->
        <div class="p-6 bg-[#141E28]/50 border border-[#1F2E3D] rounded-2xl reveal-slide space-y-3 transition-all duration-300 hover:border-[#05FFD1]/40 hover:bg-[#141E28]/80 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(5,255,209,0.05)] flex flex-col justify-between">
          <div class="space-y-3">
            <div class="flex justify-between items-start">
              <div>
                <h5 class="text-lg font-bold text-slate-200">Técnica en Data & IA</h5>
                <span class="text-xs text-slate-400 font-mono">Inetum (Prácticas)</span>
              </div>
              <span class="text-xs bg-[#05FFD1]/10 text-[#05FFD1] font-mono px-2 py-1 rounded border border-[#05FFD1]/20">Data Stage</span>
            </div>
            <ul class="text-xs text-slate-400 space-y-2 list-disc list-inside">
              <li>Desarrollo y mantenimiento de procesos ETL con Pentaho Data Integration.</li>
              <li>Gestión y optimización de consultas SQL sobre Oracle 12c y MySQL.</li>
              <li>Soporte en la automatización de procesos mediante Jenkins y Power BI.</li>
            </ul>
          </div>
        </div>

        <div class="block md:hidden mt-6"><h4 class="text-md font-space text-[#05FFD1] font-bold tracking-wider uppercase mb-4">// EDUCACIÓN ACADÉMICA</h4></div>
        <!-- DAW -->
        <div class="p-6 bg-[#141E28]/50 border border-[#1F2E3D] rounded-2xl reveal-slide space-y-2 transition-all duration-300 hover:border-[#05FFD1]/40 hover:bg-[#141E28]/80 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(5,255,209,0.05)] flex flex-col justify-between">
          <div>
            <h5 class="text-lg font-bold text-slate-200">Técnico Superior en DAW</h5>
            <span class="text-xs text-[#05FFD1] font-mono block mb-2">IES Julio Verne (Bargas, Toledo) • (2025-2026)</span>
            <p class="text-xs text-slate-400 leading-relaxed">Formación profesional oficial de grado superior orientada a la ingeniería de software web. Capacitación integral en el diseño, desarrollo y despliegue de aplicaciones y servicios digitales, abarcando tanto el desarrollo visual (Front-End) como la lógica de negocio y servidores (Back-End).</p>
          </div>
        </div>
      </div>

      <!-- FILA 2: ANDROID + DAM -->
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-stretch">
        <!-- JULIO VERNE APP -->
        <div class="p-6 bg-[#141E28]/50 border border-[#1F2E3D] rounded-2xl reveal-slide space-y-3 transition-all duration-300 hover:border-[#05FFD1]/40 hover:bg-[#141E28]/80 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(5,255,209,0.05)] flex flex-col justify-between" style="transition-delay: 0.1s;">
          <div class="space-y-3">
            <div class="flex justify-between items-start">
              <div>
                <h5 class="text-lg font-bold text-slate-200">Desarrolladora Android</h5>
                <span class="text-xs text-slate-400 font-mono">IES Julio Verne (Prácticas)</span>
              </div>
              <span class="text-xs bg-[#05FFD1]/10 text-[#05FFD1] font-mono px-2 py-1 rounded border border-[#05FFD1]/20">Mobile Stage</span>
            </div>
            <ul class="text-xs text-slate-400 space-y-2 list-disc list-inside">
              <li>Diseño y desarrollo de una aplicación móvil nativa para la gestión interna del centro educativo.</li>
              <li>Implementación de módulos críticos: control de horarios de profesores y sistema automatizado de partes de incidencias.</li>
              <li>Modelado de la base de datos local y sincronización de flujos de datos según el rol del usuario.</li>
            </ul>
          </div>
        </div>

        <!-- DAM -->
        <div class="p-6 bg-[#141E28]/50 border border-[#1F2E3D] rounded-2xl reveal-slide space-y-2 transition-all duration-300 hover:border-[#05FFD1]/40 hover:bg-[#141E28]/80 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(5,255,209,0.05)] flex flex-col justify-between" style="transition-delay: 0.1s;">
          <div>
            <h5 class="text-lg font-bold text-slate-200">Técnico Superior en DAM</h5>
            <span class="text-xs text-[#05FFD1] font-mono block mb-2">IES Julio Verne (Bargas, Toledo) • (2023-2025)</span>
            <p class="text-xs text-slate-400 leading-relaxed">Formación técnica enfocada en la creación, diseño e implementación de software robusto para diversos entornos y sistemas operativos. Especialista en la construcción de interfaces intuitivas y lógica de negocio escalable, con un fuerte enfoque en la programación orientada a objetos y la gestión de bases de datos.</p>
          </div>
        </div>
      </div>

      <!-- FILA 3: LOGÍSTICA + UCLM -->
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-stretch">
        <!-- LOGÍSTICA -->
        <div class="p-6 bg-[#141E28]/50 border border-[#1F2E3D] rounded-2xl reveal-slide space-y-3 transition-all duration-300 hover:border-[#05FFD1]/40 hover:bg-[#141E28]/80 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(5,255,209,0.05)] flex flex-col justify-between" style="transition-delay: 0.2s;">
          <div class="space-y-3">
            <div class="flex justify-between items-start">
              <div>
                <h5 class="text-lg font-bold text-slate-200">Operadora de Logística</h5>
                <span class="text-xs text-slate-400 font-mono">Laboratorios Indas / Joma Sport</span>
              </div>
              <span class="text-xs bg-[#05FFD1]/10 text-[#05FFD1] font-mono px-2 py-1 rounded border border-[#05FFD1]/20">Automatización</span>
            </div>
            <ul class="text-xs text-slate-400 space-y-2 list-disc list-inside">
              <li>Gestión de procesos logísticos en líneas de producción automatizadas.</li>
              <li>Manejo de sistemas digitales de inventario y preparación de pedidos.</li>
              <li>Control de stock y verificación de la trazabilidad en alta productividad.</li>
            </ul>
          </div>
        </div>

        <!-- UCLM -->
        <div class="p-6 bg-[#141E28]/50 border border-[#1F2E3D] rounded-2xl reveal-slide space-y-2 transition-all duration-300 hover:border-[#05FFD1]/40 hover:bg-[#141E28]/80 hover:-translate-y-1 hover:shadow-[0_10px_30px_rgba(5,255,209,0.05)] flex flex-col justify-between" style="transition-delay: 0.2s;">
          <div>
            <h5 class="text-lg font-bold text-slate-200">Grado en Ingeniería Informática (1º y 2º)</h5>
            <span class="text-xs text-[#05FFD1] font-mono block mb-2">UCLM - Universidad de Castilla-La Mancha • (2019-2022)</span>
            <p class="text-xs text-slate-400 leading-relaxed">Sólida base en fundamentos matemáticos, estructuras de datos, arquitectura de computadores y metodologías de desarrollo. Formación orientada a la resolución de problemas lógicos, el diseño de software y la optimización de sistemas.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

      <!-- 3. HABILIDADES, ARSENAL Y CERTIFICACIONES -->
      <section id="habilidades" class="py-32 bg-transparent border-t border-[#1F2E3D]/50 relative z-10">
        <div class="max-w-6xl mx-auto px-6">
          
          <div class="mb-20 text-center">
            <h2 class="text-xs font-mono uppercase text-[#05FFD1] tracking-widest mb-2">// ARSENAL TÉCNICO</h2>
            <h3 class="text-4xl font-bold font-space tracking-tight text-slate-100">
              Capacidades & Herramientas del Sistema
            </h3>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            
            <div class="bg-[#141E28]/40 border border-[#1F2E3D] p-8 rounded-3xl reveal-slide flex flex-col justify-between group hover:border-[#05FFD1]/40 transition-all duration-500">
              <div class="space-y-4">
                <div class="flex items-center gap-3">
                  <span class="text-[#05FFD1] font-mono text-sm font-bold">&lt;/&gt;</span>
                  <h4 class="text-lg font-bold font-space text-slate-200">Lenguajes de Programación</h4>
                </div>
                <div class="flex flex-wrap gap-x-3 gap-y-6 pt-4">
                  <div class="tech-tag" data-label="Java"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/java.svg" alt="Java" /></div>
                  <div class="tech-tag" data-label="Kotlin"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/kotlin.svg" alt="Kotlin" /></div>
                  <div class="tech-tag" data-label="JavaScript"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/javascript.svg" alt="JavaScript" /></div>
                  <div class="tech-tag" data-label="PHP"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/php.svg" alt="PHP" /></div>
                  <div class="tech-tag" data-label="Python"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/python.svg" alt="Python" /></div>
                  <div class="tech-tag" data-label="SQL">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.58 4 8 4s8-1.79 8-4M4 7c0-2.21 3.58-4 8-4s8 1.79 8 4m0 5c0 2.21-3.58 4-8 4s-8-1.79-8-4" />
                    </svg>
                  </div>
                  <div class="tech-tag" data-label="C#"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/csharp.svg" alt="C#" /></div>
                  <div class="tech-tag" data-label="Node.js"><img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/nodedotjs.svg" alt="Node.js" /></div>
                </div>
              </div>
            </div>

            <div class="bg-[#141E28]/40 border border-[#1F2E3D] p-8 rounded-3xl reveal-slide flex flex-col justify-between group hover:border-[#05FFD1]/40 transition-all duration-500">
              <div class="space-y-4">
                <div class="flex items-center gap-3">
                  <span class="text-[#05FFD1] text-lg">🌐</span>
                  <h4 class="text-lg font-bold font-space text-slate-200">Desarrollo Web / Frontend</h4>
                </div>
